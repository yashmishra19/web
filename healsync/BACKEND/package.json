{
  "name": "healsync-backend",
  "version": "1.0.0",
  "description": "HealSync Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev":   "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed":  "ts-node src/scripts/seed.ts"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.0.3",
    "express":           "^4.18.2",
    "express-rate-limit":"^7.1.5",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "mongoose":          "^8.0.3",
    "morgan":            "^1.10.0",
    "twilio":            "^5.13.1",
    "zod":               "^3.22.4",
    "@types/express":    "^4.17.21",
    "@types/node":       "^20.0.0",
    "@types/bcryptjs":   "^2.4.6",
    "@types/jsonwebtoken":"^9.0.0",
    "@types/cors":       "^2.8.17",
    "@types/morgan":     "^1.9.9",
    "typescript":        "^5.0.0",
    "ts-node":            "^10.9.0",
    "nodemon":           "^3.0.2"
  }
}
